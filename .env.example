# Django
DJANGO_SECRET_KEY=your-very-secret-key-change-me-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# MySQL
CONTAINER_IMAGE=<your-container-registry>/mysql:8.0
CONTAINER_DB=request_db
MYSQL_DB=requestdb
MYSQL_USER=your-db-user
MYSQL_PASSWORD=your-db-password
MYSQL_ROOT_PASSWORD=your-root-password

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:10010,http://your-domain.com

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# Approval email recipients (comma-separated)
APPROVAL_EMAIL_LIST=approver1@company.com,approver2@company.com

# Dockerfile
IMAGE_PATH=<your-container-registry>/

# backend
PIP_INDEX_URL=http://<your-pypi-repository>/simple
PIP_TRUSTED_HOST=<your-pypi-host>
BIGDATA_INDEX_URL=http://<your-bigdata-repository>/simple
BIGDATA_TRUSTED_HOST=<your-bigdata-host>

# frontend
NPM_REGISTRY_URL=http://<your-npm-registry>

# Frontend API Mode
VITE_USE_MOCK=false

# BDQ (Big Data Query) - 외부 DB 접근용
BDQ_ID=your-bdq-id
BDQ_PASSWORD=["your-bdq-password-1", "your-bdq-password-2"]

# ODBC - Cloudera Impala
ODBC_DRIVER_URL=http://<your-odbc-repository>/clouderaimpalaodbc_<version>_amd64.deb
ODBC_DRIVER_FILENAME=clouderaimpalaodbc_<version>_amd64.deb
ODBC_HOST=<your-impala-host>
ODBC_PORT=21050
ODBC_DATABASE=<your-database>
ODBC_AUTH_MECH=2
ODBC_USE_SASL=1
ODBC_UID=<your-odbc-username>
ODBC_PWD=<your-odbc-password>
ODBC_KRB_FQDN=_HOST
ODBC_KRB_REALM=
ODBC_KRB_SERVICE_NAME=impala
ODBC_SSL=0
ODBC_TSASL_BUFFER_SIZE=4000
ODBC_ROWS_PER_BLOCK=130000
